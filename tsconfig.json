{
  "compilerOptions": {
    "module": "esnext",
    "target": "es6",
    "declaration": true,
    "sourceMap": false,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "lib",
    "removeComments": false,
    "strict": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
