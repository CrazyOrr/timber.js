{
  "name": "@crazyorr/timber",
  "version": "0.3.0",
  "description": "JavaScript port of Android's timber library.",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib/",
    "src/"
  ],
  "scripts": {
    "test": "node --test",
    "test:coverage": "node --experimental-test-coverage --test",
    "demo": "node demo/index.js",
    "build": "rimraf lib && tsc && api-extractor run --local --verbose",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check-spelling": "cspell ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CrazyOrr/timber.js.git"
  },
  "bugs": {
    "url": "https://github.com/CrazyOrr/timber.js/issues"
  },
  "homepage": "https://github.com/CrazyOrr/timber.js",
  "keywords": [
    "log",
    "logger"
  ],
  "author": {
    "name": "Lei Wang",
    "email": "wanglei021212@gmail.com",
    "url": "https://github.com/CrazyOrr"
  },
  "license": "ISC",
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.0",
    "cspell": "^9.7.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
